{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Excalidraw Desktop",
  "version": "0.2.0",
  "identifier": "app.mwco.excalidraw-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:prepare && pnpm build:excalidraw && pnpm build:svelte",
    "frontendDist": "../build"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "excalidraw"
        ]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Excalidraw Desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  }
}
