{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and child webview windows",
  "windows": ["main", "libraries"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "dialog:allow-save",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    "opener:default",
    "deep-link:default",
    "core:event:default"
  ]
}
