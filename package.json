{
  "name": "excalidraw-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Unofficial, offline-first desktop client for Excalidraw on Windows, macOS, and Linux.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "NO_STRIP=true tauri build",
    "build:prepare": "svelte-kit sync",
    "build:svelte": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "changelog": "./scripts/generate-changelog.sh",
    "release:prep": "node scripts/release-prep.mjs",
    "vendor:xiaolai": "node scripts/vendor-xiaolai.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-deep-link": "2.4.8",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@tauri-apps/plugin-fs": "2.5.0",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.6.0",
    "autoprefixer": "^10.5.0",
    "conventional-changelog": "7.2.0",
    "daisyui": "^5.5.19",
    "lucide-svelte": "^1.0.1",
    "postcss": "^8.5.10",
    "svelte": "5.55.3",
    "svelte-check": "4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "5.6.2",
    "vite": "8.0.8",
    "vite-plus": "0.1.16"
  },
  "packageManager": "pnpm@10.33.0"
}
