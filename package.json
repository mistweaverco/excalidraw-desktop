{
  "name": "excalidraw-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial, offline-first desktop client for Excalidraw on Windows, macOS, and Linux.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:excalidraw && vite dev",
    "build": "NO_STRIP=true tauri build",
    "build:svelte": "vite build",
    "build:excalidraw": "node scripts/build-excalidraw.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-deep-link": "2.4.8",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@tauri-apps/plugin-fs": "2.5.0",
    "@tauri-apps/plugin-opener": "2.5.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.0",
    "svelte": "5.55.3",
    "svelte-check": "4.4.6",
    "typescript": "5.6.2",
    "vite": "8.0.8"
  },
  "packageManager": "pnpm@10.33.0"
}
