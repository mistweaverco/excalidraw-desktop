# Maintainer: mistweaverco <oss@mistweaverco.com>
pkgname=excalidraw-desktop-bin
pkgver=0.0.0 # CI will take care
pkgrel=1
pkgdesc="Unofficial, offline-first desktop client for Excalidraw on Windows, macOS, and Linux."
arch=('x86_64')
url="https://github.com/mistweaverco/excalidraw-desktop"
license=('MIT')
provides=('excalidraw-desktop')
conflicts=('excalidraw-desktop')
source_x86_64=("${pkgname}-${pkgver}.tar.gz::https://github.com/mistweaverco/excalidraw-desktop/releases/download/v${pkgver}/excalidraw-desktop_amd64.deb")

# NOTE: Auto-generated by CI via updpkgsums
sha256sums_x86_64=('AUTO_GENERATED')


package() {
  if [ -f "data.tar.xz" ]; then
    bsdtar -xf "data.tar.xz" -C "${pkgdir}"
  else
    bsdtar -xf "data.tar.gz" -C "${pkgdir}"
  fi
  mkdir -p "${pkgdir}/usr/bin"
  ln -sf "/opt/excalidraw-desktop/excalidraw-desktop" "${pkgdir}/usr/bin/excalidraw-desktop"
}
